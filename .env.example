# ===========================================
# SPADE CLOUD - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ===========================================
# DOMAIN CONFIGURATION
# ===========================================
# Replace example.com with your actual domain
DATABROKER_DOMAIN=databroker.example.com
ENTRYPOINT_DOMAIN=spade.example.com
CATALOGUE_DOMAIN=catalogue.example.com
KEYCLOAK_DOMAIN=auth.example.com
PKI_DOMAIN=pki.example.com

# ===========================================
# DOCKER IMAGE CONFIGURATION
# ===========================================
DATABROKER_UI_IMAGE=your-registry.com/databroker-ui:latest
ENTRYPOINT_IMAGE=your-registry.com/spade-entrypoint:latest
CATALOGUE_IMAGE=your-registry.com/spade-catalogue:latest

# ===========================================
# CATALOGUE DATABASE (PostgreSQL)
# ===========================================
CATALOGUE_DB_USER=catalogue_admin
CATALOGUE_DB_PASSWORD=change_this_catalogue_password
CATALOGUE_DB_NAME=catalogue

# ===========================================
# KEYCLOAK DATABASE (PostgreSQL)
# ===========================================
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak_admin
KEYCLOAK_DB_PASSWORD=change_this_keycloak_password

# ===========================================
# KEYCLOAK CONFIGURATION
# ===========================================
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_this_keycloak_admin_password
# Optional: Custom themes path (uncomment volume in docker-compose.yml)
# KEYCLOAK_THEMES_PATH=./themes/bavenir

# ===========================================
# PKI SERVICE CONFIGURATION
# ===========================================
# Paths are relative to /pki workdir inside the container (certs/ is mounted at /pki/certs)
CA_SUBCA_PATH=certs/subCA.p12
CA_SUBCA_KEY=change_this_subca_password
DB_PATH=certs/db.sqlite
# CRL_URL is embedded in issued certificates - must be the public URL of this PKI service
CRL_URL=https://pki.example.com/pki/certificates/revocation-list
CRL_EXPIRATION_DAYS=30
CERT_VALIDITY_DAYS=1825
# Expose SPADE-compatible endpoints under /api/v1 (required by SPADE catalogue)
SPADE_COMPAT=true
# Enable API secret authentication for certificate write operations
API_SECRET_ENABLED=true
API_SECRET=change_this_api_secret

# ===========================================
# ADDITIONAL CATALOGUE VARIABLES
# ===========================================
# Add any additional variables needed by the catalogue service
# These should match what's expected in your catalogue application
DB_ADMIN_USER=${CATALOGUE_DB_USER}
DB_ADMIN_PASSWORD=${CATALOGUE_DB_PASSWORD}
